  "tokenColors": [
    {
      "name": "Comentarios legibles",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#828BB8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Palabras clave",
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Funciones y Métodos",
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "Cadenas de texto",
      "scope": ["string", "punctuation.definition.string", "string.template"],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Clases, Tipos e Interfaces",
      "scope": ["entity.name.class", "entity.name.type.class", "support.type", "support.class", "entity.other.inherited-class", "entity.name.type"],
      "settings": {
        "foreground": "#FFC777"
      }
    },
    {
      "name": "Variables, Props y Atributos",
      "scope": ["variable", "variable.parameter", "meta.object-literal.key", "support.variable.property", "variable.other.property", "entity.other.attribute-name"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Etiquetas HTML/JSX",
      "scope": ["entity.name.tag", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#F07178"
      }
    },
    {
      "name": "Constantes y Números",
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Atributos CSS",
      "scope": ["entity.other.attribute-name.css", "support.type.property-name.css"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Valores CSS",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#C3E88D"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#FFC777",
    "interface": "#FFC777",
    "type": "#FFC777",
    "parameter": "#89DDFF",
    "variable": "#D5D6E1",
    "property": "#89DDFF",
    "function": "#82AAFF",
    "method": "#82AAFF",
    "keyword": "#C792EA",
    "string": "#C3E88D",
    "decorator": "#FFC777"
  }
}
