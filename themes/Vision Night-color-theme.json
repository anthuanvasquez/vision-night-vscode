  "tokenColors": [
    {
      "name": "Comentarios legibles",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#6A7191",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Palabras clave",
      "scope": ["keyword", "storage.type", "storage.modifier", "keyword.control"],
      "settings": {
        "foreground": "#B07CD6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Funciones y Métodos",
      "scope": ["entity.name.function", "meta.function-call", "support.function"],
      "settings": {
        "foreground": "#6F9EF5"
      }
    },
    {
      "name": "Cadenas de texto",
      "scope": ["string", "punctuation.definition.string", "string.template"],
      "settings": {
        "foreground": "#A9D67A"
      }
    },
    {
      "name": "Clases, Tipos e Interfaces",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "support.type",
        "support.class",
        "entity.other.inherited-class",
        "entity.name.type",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#E8B463"
      }
    },
    {
      "name": "Variables, Props y Atributos",
      "scope": ["variable", "variable.parameter", "meta.object-literal.key", "support.variable.property", "variable.other.property", "entity.other.attribute-name"],
      "settings": {
        "foreground": "#74C9E8"
      }
    },
    {
      "name": "Puntuación de etiquetas (Brackets)",
      "scope": ["punctuation.definition.tag"],
      "settings": {
        "foreground": "#A9ADC1"
      }
    },
    {
      "name": "Etiquetas HTML/JSX",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#E96A75"
      }
    },
    {
      "name": "Constantes y Números",
      "scope": ["constant.numeric", "constant.language", "constant.character", "constant.other"],
      "settings": {
        "foreground": "#FF9E64"
      }
    },
    {
      "name": "Atributos CSS",
      "scope": ["entity.other.attribute-name.css", "support.type.property-name.css"],
      "settings": {
        "foreground": "#74C9E8"
      }
    },
    {
      "name": "Valores CSS",
      "scope": ["support.constant.property-value.css"],
      "settings": {
        "foreground": "#A9D67A"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "class": "#E8B463",
    "interface": "#E8B463",
    "type": "#E8B463",
    "parameter": "#74C9E8",
    "variable": "#D5D6E1",
    "property": "#74C9E8",
    "function": "#6F9EF5",
    "method": "#6F9EF5",
    "keyword": "#B07CD6",
    "string": "#A9D67A",
    "decorator": "#E8B463"
  }
}
